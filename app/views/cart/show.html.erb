<div class="container py-4">
  <h1 class="mb-4">🛒 Shopping Cart</h1>

  <% if @cart_items.empty? %>
    <div class="alert alert-info">
      Your cart is empty. <%= link_to "Continue shopping", products_path %>
    </div>
  <% else %>
    <div class="table-responsive">
      <table class="table table-bordered align-middle">
        <thead class="table-dark">
          <tr>
            <th>Product</th>
            <th>Price</th>
            <th>Quantity</th>
            <th>Subtotal</th>
            <th>Remove</th>
          </tr>
        </thead>
        <tbody>
          <% @cart_items.each do |item| %>
            <tr>
              <td><%= link_to item[:product].name, product_path(item[:product]) %></td>
              <td><%= number_to_currency(item[:product].price) %></td>
              <td>
                <%= form_with url: update_cart_path(product_id: item[:product].id), method: :patch, local: true do |f| %>
                  <div class="input-group" style="width: 130px;">
                    <%= f.number_field :quantity, value: item[:quantity], min: 1, class: "form-control form-control-sm" %>
                    <%= f.submit "Update", class: "btn btn-sm btn-outline-secondary" %>
                  </div>
                <% end %>
              </td>
              <td><%= number_to_currency(item[:product].price * item[:quantity]) %></td>
              <td>
                <%= button_to "Remove", remove_item_cart_path(product_id: item[:product].id), method: :delete, class: "btn btn-sm btn-danger", form: { style: "display:inline" } %>
              </td>
            </tr>
          <% end %>
        </tbody>
        <tfoot>
          <tr>
            <td colspan="3" class="text-end fw-bold">Subtotal:</td>
            <td colspan="2" class="fw-bold"><%= number_to_currency(@subtotal) %></td>
          </tr>
        </tfoot>
      </table>
    </div>

    <div class="d-flex justify-content-between mt-3">
      <%= link_to "Continue Shopping", products_path, class: "btn btn-outline-secondary" %>
      <% if user_signed_in? %>
        <%= link_to "Proceed to Checkout", new_order_path, class: "btn btn-warning fw-bold" %>
      <% else %>
        <%= link_to "Login to Checkout", new_user_session_path, class: "btn btn-warning fw-bold" %>
      <% end %>
    </div>
  <% end %>
</div>
