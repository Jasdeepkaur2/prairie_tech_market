<div class="container my-4">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><%= link_to "Home", root_path %></li>
      <li class="breadcrumb-item"><%= link_to "My Orders", orders_path %></li>
      <li class="breadcrumb-item active">Order #<%= @order.id %></li>
    </ol>
  </nav>
  <div class="card">
    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
      <h4 class="mb-0">Order #<%= @order.id %></h4>
      <span class="badge bg-warning text-dark fs-6"><%= @order.status.capitalize %></span>
    </div>
    <div class="card-body">
      <p><strong>Order Date:</strong> <%= @order.order_date.strftime("%B %d, %Y") %></p>
      <p><strong>Province:</strong> <%= @order.province.name %></p>
      <table class="table">
        <thead>
          <tr>
            <th>Product</th>
            <th>Price at Purchase</th>
            <th>Quantity</th>
            <th>Subtotal</th>
          </tr>
        </thead>
        <tbody>
          <% @order_items.each do |item| %>
            <tr>
              <td><%= item.product.name %></td>
              <td><%= number_to_currency(item.price_at_purchase) %></td>
              <td><%= item.quantity %></td>
              <td><%= number_to_currency(item.price_at_purchase * item.quantity) %></td>
            </tr>
          <% end %>
        </tbody>
        <tfoot>
          <% subtotal = @order_items.sum { |i| i.price_at_purchase * i.quantity } %>
          <% tax = @order.total_amount - subtotal %>
          <tr>
            <td colspan="3" class="text-end">Subtotal:</td>
            <td><%= number_to_currency(subtotal) %></td>
          </tr>
          <tr>
            <td colspan="3" class="text-end">
              Tax (<%= @order.province.name %>
              <% if @order.province.hst > 0 %>
                HST <%= (@order.province.hst * 100).round(1) %>%
              <% else %>
                GST <%= (@order.province.gst * 100).round(1) %>%
                <% if @order.province.pst > 0 %>
                  + PST <%= (@order.province.pst * 100).round(1) %>%
                <% end %>
              <% end %>
              ):
            </td>
            <td><%= number_to_currency(tax) %></td>
          </tr>
          <tr class="fw-bold">
            <td colspan="3" class="text-end">Total:</td>
            <td class="text-success"><%= number_to_currency(@order.total_amount) %></td>
          </tr>
        </tfoot>
      </table>
    </div>
  </div>
</div>
