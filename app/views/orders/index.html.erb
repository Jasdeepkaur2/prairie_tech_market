<div class="container my-4">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><%= link_to "Home", root_path %></li>
      <li class="breadcrumb-item active">My Orders</li>
    </ol>
  </nav>
  <h1 class="mb-4">My Orders</h1>
  <% if @orders.empty? %>
    <div class="alert alert-info">You have no orders yet. <%= link_to "Start shopping", products_path %>.</div>
  <% else %>
    <div class="table-responsive">
      <table class="table table-hover">
        <thead class="table-dark">
          <tr>
            <th>Order #</th>
            <th>Date</th>
            <th>Province</th>
            <th>Total</th>
            <th>Status</th>
            <th>Details</th>
          </tr>
        </thead>
        <tbody>
          <% @orders.each do |order| %>
            <tr>
              <td>#<%= order.id %></td>
              <td><%= order.order_date.strftime("%B %d, %Y") %></td>
              <td><%= order.province.name %></td>
              <td>$<%= number_with_precision(order.total_amount, precision: 2) %></td>
              <td><span class="badge bg-warning text-dark"><%= order.status.capitalize %></span></td>
              <td><%= link_to "View", order_path(order), class: "btn btn-sm btn-outline-dark" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
