<div class="container my-4">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><%= link_to "Home", root_path %></li>
      <li class="breadcrumb-item active">Search</li>
    </ol>
  </nav>
  <h1 class="mb-4">Search Products</h1>
  <%= form_with url: search_path, method: :get, class: "mb-4" do |f| %>
    <div class="row g-2">
      <div class="col-md-6">
        <%= f.text_field :query, value: @query, placeholder: "Search by keyword...", class: "form-control form-control-lg" %>
      </div>
      <div class="col-md-3">
        <%= f.select :category_id,
          options_for_select([["All Categories", ""]] + @categories.map { |c| [c.name, c.id] }, @category_id),
          {}, class: "form-select form-select-lg" %>
      </div>
      <div class="col-md-2">
        <%= f.submit "Search", class: "btn btn-warning btn-lg w-100" %>
      </div>
    </div>
  <% end %>

  <% if @query.present? || @category_id.present? %>
    <p class="text-muted">Found <%= @products.total_count %> results</p>
    <div class="row g-3">
      <% @products.each do |product| %>
        <div class="col-md-3 col-sm-6">
          <%= render 'products/product_card', product: product %>
        </div>
      <% end %>
    </div>
    <div class="mt-4"><%= paginate @products %></div>
  <% end %>
</div>
