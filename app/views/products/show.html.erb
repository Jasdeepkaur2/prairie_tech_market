<div class="container my-4">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><%= link_to "Home", root_path %></li>
      <li class="breadcrumb-item"><%= link_to "Products", products_path %></li>
      <li class="breadcrumb-item"><%= link_to @product.category.name, category_path(@product.category) %></li>
      <li class="breadcrumb-item active"><%= @product.name %></li>
    </ol>
  </nav>
  <div class="row">
    <div class="col-md-5">
      <% if @product.image.attached? %>
        <%= image_tag @product.image, class: "img-fluid rounded shadow" %>
      <% else %>
        <div class="bg-secondary rounded d-flex align-items-center justify-content-center" style="height: 350px;">
          <span class="text-white" style="font-size: 5rem;">💻</span>
        </div>
      <% end %>
    </div>
    <div class="col-md-7">
      <h1><%= @product.name %></h1>
      <p class="text-muted"><%= link_to @product.category.name, category_path(@product.category) %></p>
      <h2 class="text-success">$<%= number_with_precision(@product.price, precision: 2) %></h2>
      <p><%= @product.description %></p>
      <p class="text-muted">In stock: <%= @product.stock %></p>
      <% if @product.stock > 0 %>
        <%= form_with url: add_item_cart_path, method: :post do |f| %>
          <%= f.hidden_field :product_id, value: @product.id %>
          <div class="d-flex align-items-center gap-2 mb-3">
            <%= f.number_field :quantity, value: 1, min: 1, max: @product.stock, class: "form-control", style: "width: 80px;" %>
            <%= f.submit "Add to Cart", class: "btn btn-warning btn-lg" %>
          </div>
        <% end %>
      <% else %>
        <p class="text-danger fw-bold">Out of Stock</p>
      <% end %>
    </div>
  </div>
</div>
