<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1>All Products</h1>
    <div class="btn-group">
      <%= link_to "All", products_path, class: "btn btn-sm #{@current_filter.nil? ? 'btn-warning' : 'btn-outline-warning'}" %>
      <%= link_to "On Sale", products_path(filter: "on_sale"), class: "btn btn-sm #{@current_filter == 'on_sale' ? 'btn-warning' : 'btn-outline-warning'}" %>
      <%= link_to "New", products_path(filter: "new"), class: "btn btn-sm #{@current_filter == 'new' ? 'btn-warning' : 'btn-outline-warning'}" %>
      <%= link_to "Recently Updated", products_path(filter: "recently_updated"), class: "btn btn-sm #{@current_filter == 'recently_updated' ? 'btn-warning' : 'btn-outline-warning'}" %>
    </div>
  </div>

  <div class="row row-cols-1 row-cols-md-3 g-4">
    <% @products.each do |product| %>
      <%= render 'product_card', product: product %>
    <% end %>
  </div>

  <div class="mt-4">
    <%= paginate @products %>
  </div>
</div>
