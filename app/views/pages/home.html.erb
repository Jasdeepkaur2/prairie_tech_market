<div class="bg-dark text-white py-5">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-md-7">
        <h1 class="display-4 fw-bold text-warning">Prairie Tech Market</h1>
        <p class="lead">Winnipeg's trusted source for computer components, gaming gear, and home office electronics.</p>
        <%= link_to "Shop Now", products_path, class: "btn btn-warning btn-lg me-3" %>
        <%= link_to "Browse Categories", products_path, class: "btn btn-outline-light btn-lg" %>
      </div>
    </div>
  </div>
</div>

<div class="container my-5">
  <h2 class="mb-4">Shop by Category</h2>
  <div class="row g-3">
    <% Category.all.each do |category| %>
      <div class="col-md-4 col-sm-6">
        <%= link_to category_path(category), class: "text-decoration-none" do %>
          <div class="card h-100 border-0 shadow-sm">
            <div class="card-body text-center py-4">
              <h5 class="card-title text-dark"><%= category.name %></h5>
              <p class="card-text text-muted small"><%= category.description %></p>
              <span class="badge bg-warning text-dark"><%= category.products.count %> products</span>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<div class="container my-5">
  <h2 class="mb-4">Featured Products</h2>
  <div class="row g-3">
    <% Product.limit(8).each do |product| %>
      <div class="col-md-3 col-sm-6">
        <%= render 'products/product_card', product: product %>
      </div>
    <% end %>
  </div>
  <div class="text-center mt-4">
    <%= link_to "View All Products", products_path, class: "btn btn-dark btn-lg" %>
  </div>
</div>
